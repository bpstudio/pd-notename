#N canvas 480 80 520 320 12;
#X text 40 30 notename - MIDI note number to English note label;
#X text 40 60 Inlet: float 0-127 (clamped). Outlet: symbol (e.g. C-4 \, C#4).;
#X text 40 90 White keys use a hyphen before the octave (C-3).;
#X text 40 110 Black keys use sharp + octave (C#3) \, no hyphen before octave.;
#X obj 40 170 nbx 5 18 -1e+37 1e+37 0 0 empty empty empty 0 -8 0 12 -262144
-1 -1 60 256;
#X obj 40 210 notename;
#X obj 40 250 print;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
